# Secrets / credentials
**/.env
**/.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# OpenClaw local runtime/state (machine-specific)
.openclaw/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python cache
__pycache__/
*.pyc
*.pyo

# Generated report/build artifacts
*.aux
*.log
*.toc
*.out

# Nested working repositories and heavy dev artifacts
workspaces/*/working/**/.git/
workspaces/*/working/**/node_modules/
